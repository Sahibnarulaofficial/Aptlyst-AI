{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@shared/*": ["packages/shared/src/*"],
      "@types/*": ["packages/types/src/*"]
    }
  }
}
